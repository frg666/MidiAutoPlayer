<UserControl x:Class="MidiAutoPlayer.View.MidiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:MidiAutoPlayer"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.Column="0" Margin="10,10,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                <TextBlock FontSize="20" Text="播放列表" />
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Bottom"
                           Foreground="Gray"
                           Text="(双击演奏)" />
            </StackPanel>
            <Border Grid.Row="1" Margin="20,10,0,0" Background="#F5F5F5" CornerRadius="8">
                <ListBox x:Name="ListBox_MidiFileInfo"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding MidiFileInfoList}"
                         MouseDoubleClick="ListBox_MidiFileInfo_MouseDoubleClick"
                         SelectedItem="{Binding SelectedMidiFile}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Text="{Binding Name}" Margin="5,3" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <Grid Grid.Row="0" Grid.Column="1" Margin="20,10,10,0" Background="#FFFFFF">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock Margin="0,0,0,10"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Text="设置" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="功能状态：" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding StateText}" />
                </StackPanel>
                <Grid Width="280" Margin="0,10,0,0" HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="自动跳转到原神窗口" />
                    <CheckBox Grid.Row="0"
                              Grid.Column="1"
                              HorizontalAlignment="Left"
                              IsChecked="{Binding AutoSwitchToGenshinWindow}"
                              VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="后台演奏(可能会卡顿)" />
                    <CheckBox Grid.Row="1"
                              Grid.Column="1"
                              HorizontalAlignment="Left"
                              IsChecked="{Binding PlayBackground}"
                              VerticalAlignment="Center" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="速度" />
                    <ui:NumberBox Grid.Row="2"
                                  Grid.Column="1"
                                  Width="100"
                                  HorizontalAlignment="Left"
                                  Minimum="0.1"
                                  Maximum="10"
                                  SmallChange="0.1"
                                  SpinButtonPlacementMode="Hidden"
                                  Value="{Binding Speed, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="升降调" />
                    <StackPanel Grid.Row="3"
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal">
                        <ui:NumberBox Width="100"
                                      HorizontalAlignment="Left"
                                      Minimum="-24"
                                      Maximum="24"
                                      SmallChange="1"
                                      SpinButtonPlacementMode="Hidden"
                                      Value="{Binding NoteLevel, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <ui:Button Grid.Row="4"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Margin="0,5,0,0"
                               Content="自动调整"
                               Appearance="Primary"
                               HorizontalAlignment="Left"
                               Click="Button_AutoAdjust_Click" />
                    <ui:Button Grid.Row="5"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Margin="0,8,0,0"
                               Content="刷新游戏窗口"
                               Appearance="Secondary"
                               HorizontalAlignment="Left"
                               Click="Button_RefreshWindow_Click" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock FontSize="20" Text="文件信息" />
                <TextBlock Margin="0,4,0,0" Text="{Binding SelectedMidiFile.Name}" />
                <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                    <TextBlock Text="总音符数：" />
                    <TextBlock Width="50" Text="{Binding SelectedMidiFile.NoteNumber}" />
                    <TextBlock Text="总可演奏音符数：" />
                    <TextBlock Width="50" Text="{Binding SelectedMidiFile.CanPlayNoteNumber}" />
                    <TextBlock Text="总命中率：" />
                    <TextBlock Text="{Binding SelectedMidiFile.CanPlayNoteRadio, StringFormat=P1}" />
                </StackPanel>
                <TextBlock Margin="0,10,0,0" FontSize="16" Text="音轨信息" />
            </StackPanel>

            <ScrollViewer Grid.Row="2">
                <ItemsControl ItemsSource="{Binding SelectedMidiFile.MidiTracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,20,10" Background="White" CornerRadius="6" Padding="4">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="ToggleButton_CheckTrack"
                                              Width="60"
                                              Click="ToggleButton_CheckTrack_Click"
                                              IsChecked="{Binding IsCheck}"
                                              VerticalAlignment="Center" />
                                    <StackPanel Margin="10,0,0,0">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                        <StackPanel Margin="0,4,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="音符数：" />
                                                <TextBlock Width="50" Text="{Binding NoteNumber}" />
                                                <TextBlock Text="可演奏音符数：" />
                                                <TextBlock Width="50" Text="{Binding CanPlayNoteNumber}" />
                                                <TextBlock VerticalAlignment="Center" Text="命中率：" />
                                                <TextBlock VerticalAlignment="Center" Text="{Binding CanPlayNoteRadio, StringFormat=P1}" />
                                                <TextBlock VerticalAlignment="Center" Text=" " />
                                                <TextBlock VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSupported}" Value="False">
                                                                    <Setter Property="Text" Value="(不支持)" />
                                                                    <Setter Property="Foreground" Value="Red" />
                                                                    <Setter Property="FontWeight" Value="Bold" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="20,10">
            <ui:Button Content="⏮" Padding="15,8" Click="Button_Back_Click" />
            <ui:Button x:Name="Button_Play" Margin="10,0" Padding="25,8" Appearance="Primary" Click="Button_Play_Click">
                <ui:Button.Content>
                    <TextBlock Text="▶" FontSize="18" />
                </ui:Button.Content>
            </ui:Button>
            <ui:Button Content="⏭" Padding="15,8" Click="Button_Forward_Click" />
            <TextBlock Margin="20,0,0,0" VerticalAlignment="Center">
                <Run Text="{Binding CurrentTime, StringFormat='{}{0:mm\\:ss}', Mode=OneWay}" />
                <Run Text=" / " />
                <Run Text="{Binding TotalTime, StringFormat='{}{0:mm\\:ss}', Mode=OneWay}" />
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="20,0,20,10">
            <TextBlock VerticalAlignment="Center" Text="当前播放：" />
            <TextBlock Text="{Binding Name}" FontWeight="Bold" />
        </StackPanel>
    </Grid>
</UserControl>
