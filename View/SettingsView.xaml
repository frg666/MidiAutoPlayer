<UserControl x:Class="MidiAutoPlayer.View.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:MidiAutoPlayer"
             mc:Ignorable="d"
             Background="#F2F2F7">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">
            <TextBlock Text="一键自动调整" FontSize="13" Foreground="#8E8E93" Margin="0,0,0,8" />
            <Border Background="White" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="扫描所有MIDI文件，自动找到最佳音调并保存。" FontSize="14" Foreground="#8E8E93" TextWrapping="Wrap" Margin="0,0,0,15" />
                    <Button x:Name="Button_AutoAdjustAll" Content="开始调整" Padding="15,12" Background="#007AFF" Foreground="White" BorderThickness="0" FontSize="15" Click="Button_AutoAdjustAll_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="TextBlock_Progress" Margin="0,10,0,0" FontSize="14" Foreground="#8E8E93" />
                </StackPanel>
            </Border>

            <TextBlock Text="批量删除" FontSize="13" Foreground="#8E8E93" Margin="0,20,0,8" />
            <Border Background="White" CornerRadius="10" Padding="15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="删除命中率低于" VerticalAlignment="Center" FontSize="14" />
                        <TextBox x:Name="TextBox_DeleteThreshold" Width="50" Text="90" FontSize="14" Margin="5,0" />
                        <TextBlock Text="%的文件" VerticalAlignment="Center" FontSize="14" />
                    </StackPanel>
                    <Button x:Name="Button_DeleteBelowThreshold" Content="删除" Padding="15,12" Background="#FF3B30" Foreground="White" BorderThickness="0" FontSize="15" Click="Button_DeleteBelowThreshold_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock x:Name="TextBlock_FileCount" Foreground="#8E8E93" FontSize="13" Margin="0,20,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
